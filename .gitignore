# Binaries (anchored to repo root so we don't accidentally ignore the Helm
# chart dir deploy/helm/kubernetes-mcp/ or other paths of the same name).
/bin/
/dist/
/kubernetes-mcp
/kubernetes-mcp-server

# Test artifacts
*.out
*.test
coverage.*

# Local config / secrets — never commit real cluster creds
/kubeconfig
*.env
.env
/etc-kmcp/

# envtest downloaded assets
/.envtest/

# OS / editor
.DS_Store
